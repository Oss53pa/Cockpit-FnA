# ════════════════════════════════════════════════════════════════════
# Cockpit FnA — Variables d'environnement
# Copier en .env.local pour le dev, configurer dans Vercel pour la prod.
# ════════════════════════════════════════════════════════════════════

# ── Supabase (obligatoire) ─────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role (Edge Functions uniquement, NE JAMAIS exposer côté front)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Email (Edge Functions Resend) ──────────────────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM=Cockpit FnA <noreply@cockpit-fna.app>
RESEND_FROM_COCKPIT=Cockpit FnA <noreply@cockpit-fna.app>
FROM_EMAIL=noreply@cockpit-fna.app

# ── Ollama IA locale (optionnel — si non configuré, fallback rules-based) ──
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_BASE=http://localhost:11434
VITE_OLLAMA_MODEL=llama3.1:8b

# ── Atlas Studio Marketplace (optionnel) ────────────────────────────
VITE_ATLAS_STUDIO_URL=https://atlas-studio.app

# ── Atlas Studio « Proph3t core » (fédération + mode hébergé) ───────
# Pointent sur le projet Supabase du CORE Atlas (PAS forcément celui de l'app).
# Pour Cockpit F&A, l'app tourne déjà sur le projet core → mêmes valeurs que
# VITE_SUPABASE_*. Sans ces vars, src/lib/proph3t.ts retombe sur VITE_SUPABASE_*.
# Ne JAMAIS committer une vraie clé — uniquement via .env / secrets Vercel.
VITE_ATLAS_SUPABASE_URL=https://vgtmljfayiysuvrcmunt.supabase.co
VITE_ATLAS_SUPABASE_ANON_KEY=your-atlas-core-anon-key

# ── Sentry (suivi d'erreurs — optionnel) ───────────────────────────
# DSN public du projet Sentry. Sans DSN, Sentry reste désactivé.
# N'envoie les events qu'en build de production (cf. src/lib/sentry.ts).
VITE_SENTRY_DSN=
# Optionnel : version de release affichée dans Sentry
# VITE_APP_VERSION=
#
# Upload des source maps au build (stack traces lisibles en prod).
# Côté serveur de build UNIQUEMENT (Vercel) — NE JAMAIS committer le token.
# Si SENTRY_AUTH_TOKEN est absent, le build n'upload rien (no-op).
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=mon-org-slug
# SENTRY_PROJECT=mon-projet-slug
# SENTRY_URL=https://de.sentry.io   # région EU (défaut)
